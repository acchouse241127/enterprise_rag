# ===========================================
# Enterprise RAG System - 环境变量配置
# ===========================================

# 应用基础配置
APP_NAME=Enterprise RAG System
APP_VERSION=1.0.0
API_PREFIX=/api
LOG_LEVEL=INFO

# ===========================================
# 数据库配置
# ===========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=enterprise_rag
POSTGRES_USER=enterprise_rag
POSTGRES_PASSWORD=enterprise_rag

# ChromaDB 向量数据库
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_PREFIX=kb

# ===========================================
# 文档处理配置
# ===========================================
UPLOAD_ROOT_DIR=../data/uploads
MAX_FILE_SIZE_MB=200
CHUNK_SIZE=800
CHUNK_OVERLAP=100
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_FALLBACK_DIM=64
RETRIEVAL_TOP_K=5
# 检索质量看板：为 true 时记录每次问答的检索日志，看板才有数据
RETRIEVAL_LOG_ENABLED=true
# 速度优化：关闭 Reranker 可明显缩短首字等待（约 3~8 秒），排序略弱；减小候选数也加快
# RERANKER_ENABLED=false
# RERANKER_CANDIDATE_K=10
# 检索过滤：向量距离阈值；Reranker 最低分
# DYNAMIC_THRESHOLD_FALLBACK=0.8
# DYNAMIC_THRESHOLD_MIN=0.0

# ===========================================
# LLM 配置（Kimi K2.5 / OpenAI 兼容）
# ===========================================
# Kimi: https://platform.moonshot.ai/console/api-keys 国内用 .cn
LLM_PROVIDER=openai
LLM_API_KEY=your-moonshot-api-key-here
LLM_BASE_URL=https://api.moonshot.cn/v1
LLM_MODEL_NAME=kimi-k2.5
LLM_TEMPERATURE=1
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=1.0

# ===========================================
# 安全配置（生产环境请务必修改）
# ===========================================
JWT_SECRET_KEY=please-change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# Docker 部署配置（可选）
# ===========================================
BACKEND_PORT=8000
SPA_PORT=3000
# 分享链接基地址（用于生成可访问的完整 URL，生产环境改为实际前端域名）
FRONTEND_BASE_URL=http://localhost:3000
# SPA 构建时后端地址（Docker 下留空由 nginx 代理 /api；本地 dev 由 Vite 代理，也留空）
# VITE_API_BASE=

# ===========================================
# V2.0 质量保障配置
# ===========================================
# 是否启用答案验证（NLI 模型加载较慢，生产环境建议开启）
VERIFICATION_ENABLED=true
# 置信度阈值（低于此值可能触发 FILTER 或 REFUSE）
VERIFICATION_CONFIDENCE_THRESHOLD=0.5
# 引用准确度阈值
VERIFICATION_CITATION_THRESHOLD=0.5
# 拒答阈值（低于此值将拒答）
VERIFICATION_REFUSAL_THRESHOLD=0.3

# ===========================================
# V2.1 Phase 2: Docling PDF 解析器配置
# ===========================================
# PDF 解析器后端: "docling" (默认) | "legacy"
PDF_PARSER_BACKEND=docling
# Docling OCR 开关（扫描 PDF）
DOCLING_OCR_ENABLED=true
# 提取图片的存储子目录
DOCLING_IMAGES_SUBDIR=images

# ===========================================
# V2.1 Phase 3: VLM 图片描述配置
# ===========================================
# 是否启用 VLM 图片描述（默认关闭，需配置 API Key）
VLM_ENABLED=false
# VLM 提供者: "openai" | "deepseek"
VLM_PROVIDER=openai
# VLM API Key（如与 LLM 相同可留空复用）
VLM_API_KEY=
# VLM API 地址（留空则使用 LLM 配置）
VLM_BASE_URL=
# VLM 模型名称
VLM_MODEL_NAME=gpt-4o-mini
# VLM 最大生成 token 数
VLM_MAX_TOKENS=500
# VLM 请求超时时间
VLM_TIMEOUT_SECONDS=60
# VLM 最大重试次数
VLM_MAX_RETRIES=3

# ===========================================
# OpenTelemetry 分布式追踪配置
# ===========================================
# 环境类型：development | staging | production
ENVIRONMENT=development
# OTLP Collector 端点（生产环境配置）
# Jaeger: http://jaeger:14268/api/v2/spans
# Tempo: http://tempo:3200/api/traces
# Grafana Tempo: https://<grafana-domain>/tempo/api/traces
OTLP_ENDPOINT=

# ===========================================
# React Query 配置（数据缓存和请求优化）
# ===========================================
# 数据新鲜时间（毫秒）- 超过此时间认为数据过期
REACT_QUERY_STALE_TIME=300000
# 垃圾回收时间（毫秒）- 清理未使用的缓存数据
REACT_QUERY_GC_TIME=600000
# 窗口重新获取是否启用
REACT_QUERY_REFETCH_ON_FOCUS=true

