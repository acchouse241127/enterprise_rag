# SSH 隧道配置（用于外网访问 SPA 前端）
# 复制为 .env.tunnel 并填写实际值后，运行 scripts/start-spa-tunnel.ps1

TUNNEL_VPS_HOST=your-vps-ip-or-domain
TUNNEL_VPS_USER=your-ssh-username

# 本机 SPA 端口（需与 docker-compose 中 SPA_PORT 一致，默认 3000）
TUNNEL_LOCAL_PORT=3000

# VPS 上隧道监听端口（需与 VPS 上 Nginx proxy_pass 一致，默认 10080）
TUNNEL_REMOTE_PORT=10080
